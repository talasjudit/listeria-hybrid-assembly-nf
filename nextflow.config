/*
========================================================================================
    Hybrid Bacterial Genome Assembly Pipeline - Nextflow Configuration
========================================================================================
    Github: https://github.com/talasjudit/listeria-hybrid-assembly-nf
----------------------------------------------------------------------------------------
*/

/*
========================================================================================
    PLUGINS
========================================================================================
    Using nf-schema for parameter and samplesheet validation
    Plugin is cached during installation workflow (workflows/install.nf)
    This allows the pipeline to run on compute nodes without internet access
*/

plugins {
    id 'nf-schema@2.0.0'
}

/*
========================================================================================
    PARAMETERS
========================================================================================
*/

params {
    /*
     * Input/Output Options
     * These are the only REQUIRED parameters for running the pipeline
     */
    input                        = null    // Path to samplesheet CSV file (REQUIRED)
    outdir                       = 'results'
    tracedir                     = null  // Set dynamically below

    /*
     * Container Settings
     * Configure Singularity container handling
     */
    singularity_cachedir         = "${launchDir}/singularity_cache"
    singularity_pull_docker_container = false

    /*
     * Assembly Strategy
     * Select the assembly mode for the pipeline.
     *
     * unicycler       (default): Unicycler hybrid assembly (Illumina + Nanopore)
     * flye_unicycler           : Flye long-read assembly → Unicycler (--existing_long_read_assembly)
     * flye_polypolish          : Flye long-read assembly → Polypolish (Illumina polishing)
     *
     * genome_size is required for the two Flye-based modes.
     * reference      (optional): Path to reference FASTA for dnadiff QC (flye_polypolish only)
     */
    assembly_mode                = 'unicycler'
    genome_size                  = '3m'    // Expected genome size for Flye (e.g., '3m' for 3 megabases)
    reference                    = null    // Optional reference FASTA for dnadiff (flye_polypolish mode only)

    /*
     * QC Thresholds
     * These thresholds generate warnings but do not stop the pipeline
     * Adjust based on your specific requirements
     */
    
    // Filtlong parameters
    min_read_length     = 6000    // Minimum nanopore read length (bp)
    filtlong_keep_percent = 95    // Keep top X% by quality
    // Coverage thresholds (for COVERAGE_CHECK)
    min_illumina_coverage = 30    // Minimum Illumina coverage (30X)
    min_nanopore_coverage = 20    // Minimum Nanopore coverage (20X)
    // genome_size is defined above in Assembly Strategy section
    
    /*
     * Resource Limits
     * Maximum resources that can be requested by any single process
     * These can be overridden on the command line or in custom config files
     */
    max_cpus                     = 12
    max_memory                   = '128.GB'
    max_time                     = '24.h'

    /*
     * MultiQC Options
     * Customize the final aggregated QC report
     */
    multiqc_title                = 'Hybrid Assembly Report'

    /*
     * Validation Options
     * nf-schema plugin settings
     */
    validate_params              = true

    /*
     * Boilerplate Options
     */
    help                         = false
    version                      = false
}

/*
========================================================================================
    PROFILES
========================================================================================
    Profiles combine configuration files for different execution environments

    Usage:
      nextflow run main.nf -profile singularity,slurm
      nextflow run main.nf -profile singularity,local
      nextflow run main.nf -profile test
*/

profiles {
    /*
     * CI Profile
     * For GitHub Actions stub runs. Local executor, no Singularity.
     * Containers are not executed in stub mode so no SIF files are needed.
     */
    ci {
        includeConfig 'conf/base.config'
        process.executor    = 'local'
        singularity.enabled = false
        params.outdir       = 'results_ci'
        params.max_cpus     = 2
        params.max_memory   = '6.GB'
        params.max_time     = '1.h'
    }

    /*
     * Singularity Profile
     * Explicit singularity override (rarely needed)
     * Note: Singularity is auto-enabled in slurm, qib, local, and test profiles
     */
    singularity {
        singularity.enabled      = true
        singularity.autoMounts   = true
        singularity.cacheDir     = params.singularity_cachedir
    }

    /*
     * SLURM Profile (Generic)
     * For any HPC with SLURM scheduler
     * Uses system default partition - customize with -c my_hpc.config
     */
    slurm {
        includeConfig 'conf/base.config'
        includeConfig 'conf/slurm.config'
    }

    /*
     * QIB Profile
     * Quadram Institute / NBI HPC specific settings
     * Partitions: qib-short (≤2h), qib-medium (>2h)
     */
    qib {
        includeConfig 'conf/base.config'
        includeConfig 'conf/slurm.config'
        includeConfig 'conf/qib.config'
    }

    /*
     * Local Profile
     * For local workstation/laptop execution
     * Uses local executor with limited parallelism
     */
    local {
        includeConfig 'conf/base.config'
        includeConfig 'conf/local.config'
    }

    /*
     * Test Profile
     * Moderate resources for testing with real data
     * Combine with executor profile: -profile test,qib or -profile test,local
     */
    test {
        includeConfig 'conf/base.config'
        includeConfig 'conf/test.config'
    }
}

/*
========================================================================================
    EXECUTION REPORTS
========================================================================================
    Nextflow automatically generates execution reports and trace files
    These help with debugging, optimization, and documentation
*/

timeline {
    enabled                      = true
    file                         = "${params.outdir}/pipeline_info/execution_timeline.html"
    overwrite                    = true
}

report {
    enabled                      = true
    file                         = "${params.outdir}/pipeline_info/execution_report.html"
    overwrite                    = true
}

trace {
    enabled                      = true
    file                         = "${params.outdir}/pipeline_info/execution_trace.txt"
    overwrite                    = true
}

dag {
    enabled                      = true
    file                         = "${params.outdir}/pipeline_info/pipeline_dag.svg"
    overwrite                    = true
}

/*
========================================================================================
    MANIFEST
========================================================================================
    Metadata about the pipeline
*/

manifest {
    name                         = 'listeria-hybrid-assembly-nf'
    author                       = 'Judit Talas'
    homePage                     = 'https://github.com/talasjudit/listeria-hybrid-assembly-nf'
    description                  = 'Hybrid bacterial genome assembly pipeline using Illumina and Nanopore data'
    mainScript                   = 'main.nf'
    nextflowVersion              = '>=23.04.0'
    version                      = '1.0.0dev'
}

/*
========================================================================================
    NEXTFLOW OPTIONS
========================================================================================
*/

// Ensure DSL2 syntax
nextflow.enable.dsl              = 2

// Continue past individual sample failures for batch processing (check trace for failures)
workflow.failOnError             = false
